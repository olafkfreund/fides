# Copy to .env (git-ignored) and fill with real values. Never commit .env.
#
# Generate strong random secrets, e.g.:
#   FIDES_ENCRYPTION_KEY:  head -c 32 /dev/urandom | base64
#   FIDES_API_TOKEN:       head -c 32 /dev/urandom | base64
#   passwords:             head -c 24 /dev/urandom | base64

# Postgres
POSTGRES_PASSWORD=

# MinIO (object storage)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Evidence encryption key — 32 random bytes, base64-encoded (used by server + CLI)
FIDES_ENCRYPTION_KEY=

# Bearer token required to authenticate against /api/v1 endpoints
FIDES_API_TOKEN=
